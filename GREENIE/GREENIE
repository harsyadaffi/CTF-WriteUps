for row in grid:
    for ci in row:
        html.append(
            f"<div style='display:inline-block;width:20px;height:20px;background:{PALETTE[ci]};margin:0;padding:0;'></div>"
        )
    html.append("<br>")
html.append("</div></body></html>")

with open("flag.html", "w") as f:
    f.write("\n".join(html))                                                                                                                                                                                                                                           
