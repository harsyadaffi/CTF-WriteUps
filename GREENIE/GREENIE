    "#8ddf73", 
    "#96e77b",  
    "#9fef84",  
    "#a8f78d",  
    "#b1ff96", 
    "#baff9f",
]

grid = [[random.choice([i for i in range(len(PALETTE)) if i != 7]) for _ in range(len(alphabet))] for _ in range(len(flag) ** 2)]
for r, ch in enumerate(flag):
    grid[r][ai[ch]] = [*range(7,8)][0]

